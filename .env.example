# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# Sanity API token with viewer role (for draft mode)
SANITY_API_TOKEN=

# Shared secret for Sanity webhook HMAC validation
SANITY_REVALIDATE_SECRET=

# Secret for draft mode preview URL (share with editors)
SANITY_PREVIEW_SECRET=

# Google Analytics 4 measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Database (Neon PostgreSQL)
# Source: Neon Console (https://console.neon.tech) -> Create Project -> Connection Details -> Connection string (pooled)
DATABASE_URL=

# Better Auth
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Application URL (used by auth client)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth
# Source: Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gmail API (transactional emails)
# Uses the same GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET as OAuth above.
# 1. Enable Gmail API in Google Cloud Console -> APIs & Services -> Library
# 2. Get refresh token: visit https://developers.google.com/oauthplayground
#    - Settings (gear icon) -> check "Use your own OAuth credentials" -> enter Client ID & Secret
#    - Step 1: Select "Gmail API v1 > https://www.googleapis.com/auth/gmail.send" -> Authorize
#    - Step 2: Exchange authorization code for tokens -> copy "Refresh token"
GMAIL_REFRESH_TOKEN=
# The email address to send from (must match the authorized Gmail account)
GMAIL_SENDER_EMAIL=

# Admin Setup
ADMIN_EMAIL=
ADMIN_INITIAL_PASSWORD=
